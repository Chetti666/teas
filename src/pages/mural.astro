---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Mural | TEAS" description="Intervenciones urbanas y murales de TEAS.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <h1 class="font-display text-3xl font-bold tracking-widest uppercase text-ink mb-2">Mural</h1>
    <p class="text-sm text-muted mb-10">Intervenciones urbanas y colaboraciones de gran escala</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <article class="bg-white border border-ink/10 shadow-brush">
        <div class="aspect-[4/3] bg-surface flex items-center justify-center">
          <p class="text-sm text-muted">Próximamente — Galería de murales</p>
        </div>
        <div class="p-5">
          <h3 class="font-display text-lg font-bold uppercase tracking-widest text-ink">metro21.cl</h3>
          <p class="text-sm text-muted mt-2">Colaboración en intervención urbana de gran escala. 2024</p>
        </div>
      </article>

      <article class="bg-white border border-ink/10 shadow-brush">
        <div class="aspect-[4/3] bg-surface flex items-center justify-center">
          <p class="text-sm text-muted">Próximamente — Galería de murales</p>
        </div>
        <div class="p-5">
          <h3 class="font-display text-lg font-bold uppercase tracking-widest text-ink">Mural Centro Cultural</h3>
          <p class="text-sm text-muted mt-2">Intervención site-specific. Valparaíso, 2023</p>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
