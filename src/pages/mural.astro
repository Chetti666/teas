---
import BaseLayout from "../layouts/BaseLayout.astro";

const murales = [
  {
    id: "muro3",
    title: "Memorias de Mar",
    location: "Av Irarrázabal, Santiago Chile, 2026",
    principal: "/images/murales/muro3_principal.jpg",
    proceso: [
      "/images/murales/muro3_a.jpg",
      "/images/murales/muro3_b.jpg",
      "/images/murales/muro3_principal.jpg",
    ],
  },
  {
    id: "muro2",
    title: "Mujer del Campo",
    location: "Isla del Guindo, 2026",
    principal: "/images/murales/muro2_principal.jpg",
    proceso: [
      "/images/murales/muro2_a.jpg",
      "/images/murales/muro2b.jpg",
      "/images/murales/muro2c.jpg",
    ],
  },
  {
    id: "muro1",
    title: "Ejercicios de expresión",
    location: "Batuco, comuna de Lampa, 2026",
    principal: "/images/murales/muro1_principal.jpeg",
    proceso: [
      "/images/murales/boceto.jpg",
      "/images/murales/muro1_a.jpg",
      "/images/murales/muro1_b.jpg",
      "/images/murales/muro1_c.jpg",
      "/images/murales/muro1_d.jpg",
    ],
  },
];
---

<BaseLayout
  title="Murales Urbanos | TEAS — Arte Contemporáneo"
  description="Murales, graffiti e intervenciones urbanas de TEAS. Arte contemporáneo en espacios públicos de Santiago. Proyectos de gran escala y arte callejero."
  ogType="article"
  canonical="/mural"
>
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-24 animate-reveal">
    <div class="space-y-16">
      {
        murales.map((mural, i) => (
          <article
            class="group cursor-pointer w-full"
            style={`animation: reveal 0.7s ease-out ${i * 120}ms forwards; opacity: 0;`}
            data-mural={mural.id}
          >
            <div class="max-w-4xl lg:max-w-6xl mx-auto">
              <div class="bg-surface overflow-hidden">
                <img
                  src={mural.principal}
                  alt={`${mural.title} — mural contemporáneo de TEAS, intervención urbana en Santiago`}
                  class="w-full h-auto transition-transform duration-1000 group-hover:scale-[1.01]"
                  loading={i === 0 ? "eager" : "lazy"}
                />
              </div>
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-display text-sm font-bold uppercase tracking-[0.12em] text-ink">
                    {mural.title}
                  </h3>
                  <p class="text-xs text-muted/70">{mural.location}</p>
                </div>
                <span class="text-[11px] text-muted/50 uppercase tracking-[0.1em] whitespace-nowrap group-hover:text-accent transition-colors duration-300">Ver más →</span>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <div id="mural-modal" class="fixed inset-0 z-50 hidden">
    <div
      class="absolute inset-0 bg-white/95 backdrop-blur-sm"
      id="modal-backdrop"
    >
    </div>
    <div
      class="relative z-10 h-full flex flex-col items-center justify-center px-4 py-12"
    >
      <button
        id="modal-close"
        class="absolute top-6 right-6 text-ink/70 hover:text-ink text-2xl leading-none transition-colors"
        >&times;</button
      >
      <div class="max-w-5xl w-full">
        <div
          id="modal-gallery"
          class="grid grid-cols-1 md:grid-cols-2 gap-6 max-h-[70vh] overflow-y-auto"
        >
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const muralesData = {
    muro1: {
      title: "Muro 1",
      images: [
        "/images/murales/boceto.jpg",
        "/images/murales/muro1_a.jpg",
        "/images/murales/muro1_b.jpg",
        "/images/murales/muro1_c.jpg",
        "/images/murales/muro1_d.jpg",
      ],
    },
    muro2: {
      title: "Muro 2",
      images: [
        "/images/murales/muro2_a.jpg",
        "/images/murales/muro2b.jpg",
        "/images/murales/muro2c.jpg",
      ],
    },
    muro3: {
      title: "Muro 3",
      images: [
        "/images/murales/muro3_a.jpg",
        "/images/murales/muro3_b.jpg",
        "/images/murales/muro3_principal.jpg",
      ],
    },
  };

  document.querySelectorAll("[data-mural]").forEach((el) => {
    el.addEventListener("click", () => {
      const id = el.dataset.mural;
      const data = muralesData[id];
      if (!data) return;
      const gallery = document.getElementById("modal-gallery");
      gallery.innerHTML = data.images
        .map(
          (src) =>
            `<div class="overflow-hidden rounded-sm shadow-subtle">
          <img src="${src}" alt="Proceso creativo del mural ${data.title} de TEAS" class="w-full h-auto object-cover" loading="lazy" />
        </div>`,
        )
        .join("");
      document.getElementById("mural-modal").classList.remove("hidden");
      document.body.style.overflow = "hidden";
    });
  });

  function closeMural() {
    document.getElementById("mural-modal").classList.add("hidden");
    document.body.style.overflow = "";
  }

  document
    .getElementById("modal-backdrop")
    .addEventListener("click", closeMural);
  document.getElementById("modal-close").addEventListener("click", closeMural);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMural();
  });
</script>
