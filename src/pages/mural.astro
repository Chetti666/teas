---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Mural | TEAS" description="Intervenciones urbanas y murales de TEAS.">
  <section class="max-w-6xl mx-auto px-6 py-24 animate-reveal">
    <div class="max-w-xl">
      <h1 class="font-display text-3xl font-bold tracking-[0.15em] uppercase text-ink mb-2">Mural</h1>
      <p class="text-sm text-muted/70">Intervenciones urbanas y colaboraciones de gran escala</p>
    </div>
    <div class="h-px w-16 bg-stone my-8" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <article class="bg-white shadow-subtle shadow-brush transition-all duration-500 hover:shadow-subtle-lg" style="animation: reveal 0.7s ease-out 0.1s forwards; opacity: 0;">
        <div class="aspect-[4/3] bg-surface flex items-center justify-center">
          <p class="text-xs text-muted/50 uppercase tracking-[0.15em]">Próximamente</p>
        </div>
        <div class="p-6">
          <h3 class="font-display text-base font-semibold uppercase tracking-[0.12em] text-ink">metro21.cl</h3>
          <p class="text-sm text-muted/70 mt-2 leading-relaxed">Colaboración en intervención urbana de gran escala. 2024</p>
        </div>
      </article>

      <article class="bg-white shadow-subtle shadow-brush transition-all duration-500 hover:shadow-subtle-lg" style="animation: reveal 0.7s ease-out 0.2s forwards; opacity: 0;">
        <div class="aspect-[4/3] bg-surface flex items-center justify-center">
          <p class="text-xs text-muted/50 uppercase tracking-[0.15em]">Próximamente</p>
        </div>
        <div class="p-6">
          <h3 class="font-display text-base font-semibold uppercase tracking-[0.12em] text-ink">Mural Centro Cultural</h3>
          <p class="text-sm text-muted/70 mt-2 leading-relaxed">Intervención site-specific. Valparaíso, 2023</p>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>