---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Contacto | TEAS" description="Contacta con TEAS para consultas, colaboraciones y adquisiciones.">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="font-display text-3xl font-bold tracking-widest uppercase text-ink mb-2">Contacto</h1>
    <p class="text-sm text-muted mb-10">Consultas, colaboraciones y adquisiciones</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <form class="space-y-5" onsubmit="event.preventDefault(); alert('Mensaje enviado. Gracias por contactar a TEAS.')">
          <div>
            <label for="name" class="block text-sm font-medium text-ink mb-1">Nombre</label>
            <input
              type="text"
              id="name"
              required
              class="w-full px-4 py-2.5 text-sm border border-stone bg-white text-ink placeholder:text-muted/50 focus:outline-none focus:border-ink transition-colors"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-ink mb-1">Email</label>
            <input
              type="email"
              id="email"
              required
              class="w-full px-4 py-2.5 text-sm border border-stone bg-white text-ink placeholder:text-muted/50 focus:outline-none focus:border-ink transition-colors"
              placeholder="tu@email.com"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-ink mb-1">Mensaje</label>
            <textarea
              id="message"
              rows="5"
              required
              class="w-full px-4 py-2.5 text-sm border border-stone bg-white text-ink placeholder:text-muted/50 focus:outline-none focus:border-ink transition-colors resize-none"
              placeholder="Escribe tu mensaje aquí..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-3 text-sm font-bold text-white bg-ink hover:bg-accent transition-colors uppercase tracking-widest shadow-brush"
          >
            Enviar mensaje
          </button>
        </form>
      </div>

      <div class="space-y-8">
        <div>
          <h3 class="font-display text-sm font-bold uppercase tracking-widest text-ink mb-3">Redes sociales</h3>
          <ul class="space-y-2">
            <li>
              <a href="#" class="text-sm text-muted hover:text-ink transition-colors">Instagram &rarr;</a>
            </li>
            <li>
              <a href="#" class="text-sm text-muted hover:text-ink transition-colors">Behance &rarr;</a>
            </li>
            <li>
              <a href="#" class="text-sm text-muted hover:text-ink transition-colors">LinkedIn &rarr;</a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="font-display text-sm font-bold uppercase tracking-widest text-ink mb-3">Newsletter</h3>
          <p class="text-sm text-muted mb-4">Acceso exclusivo a nuevos proyectos y ediciones.</p>
          <form class="flex gap-2" onsubmit="event.preventDefault(); alert('¡Gracias por suscribirte!')">
            <input
              type="email"
              placeholder="tu@email.com"
              required
              class="flex-1 px-3 py-2 text-sm border border-stone bg-white text-ink placeholder:text-muted/50 focus:outline-none focus:border-ink transition-colors"
            />
            <button
              type="submit"
              class="px-4 py-2 text-sm font-bold text-white bg-ink hover:bg-accent transition-colors uppercase tracking-wider"
            >
              OK
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
