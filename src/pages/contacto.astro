---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Contacto | TEAS — Artista Contemporáneo Chileno"
  description="Contacta con Seba TEAS para consultas, colaboraciones, murales y adquisiciones de obras. Artista contemporáneo chileno especializado en pintura acrílica y retratos."
  ogType="website"
  canonical="/contacto"
>
  <section class="max-w-4xl mx-auto px-6 py-24 animate-reveal">
    <div class="max-w-xl">
      <h1 class="font-display text-3xl font-bold tracking-[0.15em] uppercase text-ink mb-2">Contacto</h1>
      <p class="text-sm text-muted/70">Consultas, colaboraciones y adquisiciones</p>
    </div>
    <div class="h-px w-16 bg-stone my-8" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <div style="animation: reveal 0.7s ease-out 0.1s forwards; opacity: 0;">
        <form class="space-y-6" onsubmit="event.preventDefault(); alert('Mensaje enviado. Gracias por contactar a TEAS.')">
          <div>
            <label for="name" class="block text-xs font-medium text-ink mb-2 uppercase tracking-[0.12em]">Nombre</label>
            <input
              type="text"
              id="name"
              required
              class="w-full px-4 py-3 text-sm border border-stone bg-white text-ink placeholder:text-muted/30 focus:outline-none focus:border-ink transition-all duration-300"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="email" class="block text-xs font-medium text-ink mb-2 uppercase tracking-[0.12em]">Email</label>
            <input
              type="email"
              id="email"
              required
              class="w-full px-4 py-3 text-sm border border-stone bg-white text-ink placeholder:text-muted/30 focus:outline-none focus:border-ink transition-all duration-300"
              placeholder="tu@email.com"
            />
          </div>
          <div>
            <label for="message" class="block text-xs font-medium text-ink mb-2 uppercase tracking-[0.12em]">Mensaje</label>
            <textarea
              id="message"
              rows="5"
              required
              class="w-full px-4 py-3 text-sm border border-stone bg-white text-ink placeholder:text-muted/30 focus:outline-none focus:border-ink transition-all duration-300 resize-none"
              placeholder="Escribe tu mensaje aquí..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-3.5 text-xs font-bold text-white bg-ink hover:bg-accent transition-all duration-300 uppercase tracking-[0.2em] shadow-brush hover:shadow-brush-lg"
          >
            Enviar mensaje
          </button>
        </form>
      </div>

      <div class="space-y-10" style="animation: reveal 0.7s ease-out 0.2s forwards; opacity: 0;">
        <div>
          <h3 class="font-display text-sm font-bold uppercase tracking-[0.15em] text-ink mb-4">Redes sociales</h3>
          <ul class="space-y-3">
            <li>
              <a href="https://instagram.com/teas.1" target="_blank" rel="noopener noreferrer" class="text-sm text-muted/70 hover:text-ink transition-colors duration-300">Instagram &rarr;</a>
            </li>
            <li>
              <a href="mailto:Sebateas1@gmail.com" class="text-sm text-muted/70 hover:text-ink transition-colors duration-300">Email &rarr;</a>
            </li>
            <li>
              <a href="https://wa.me/56976191303" target="_blank" rel="noopener noreferrer" class="text-sm text-muted/70 hover:text-ink transition-colors duration-300">WhatsApp &rarr;</a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="font-display text-sm font-bold uppercase tracking-[0.15em] text-ink mb-4">Newsletter</h3>
          <p class="text-sm text-muted/70 mb-4 leading-relaxed">Acceso exclusivo a nuevos proyectos y ediciones.</p>
          <form class="flex gap-2" onsubmit="event.preventDefault(); alert('¡Gracias por suscribirte!')">
            <input
              type="email"
              placeholder="tu@email.com"
              required
              class="flex-1 min-w-0 px-3 py-2.5 text-sm border border-stone bg-white text-ink placeholder:text-muted/30 focus:outline-none focus:border-ink transition-all duration-300"
            />
            <button
              type="submit"
              class="shrink-0 px-5 py-2.5 text-xs font-bold text-white bg-ink hover:bg-accent transition-all duration-300 uppercase tracking-[0.12em]"
            >
              OK
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>