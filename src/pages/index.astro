---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroSection from '../components/HeroSection.astro'
import ArtCard from '../components/ArtCard.astro'
import obras from '../data/obras.json' with { type: 'json' }

const randomObras = [...obras].sort(() => Math.random() - 0.5).slice(0, 3)
---

<BaseLayout
  title="TEAS | Arte Contemporáneo — Pintura Acrílica, Retratos y Murales"
  description="Seba TEAS, artista contemporáneo chileno. Explora su portafolio de pintura acrílica, retratos expresivos, murales y graffiti. Obras originales en canvas y técnicas mixtas."
  ogType="website"
  canonical="/"
>
  <HeroSection
    image="/images/murales/muro1_principal.jpg"
    alt="Calipso — retrato contemporáneo en acrílico sobre lienzo de TEAS, obra destacada"
    title="TEAS"
  />

  <section class="max-w-6xl mx-auto px-6 py-24 animate-reveal">
    <div class="max-w-xl">
      <h2 class="font-display text-2xl font-bold tracking-[0.15em] uppercase text-ink mb-2">Obras recientes</h2>
      <p class="text-sm text-muted/70">Selección de retratos y estudios, 2026</p>
    </div>
    <div class="h-px w-16 bg-stone my-8" />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {randomObras.map((obra, i) => (
        <div style={`animation: reveal 0.7s ease-out ${i * 120}ms forwards; opacity: 0;`}>
          <ArtCard
            title={obra.title}
            image={obra.image}
            alt={obra.alt}
            year={obra.year}
            technique={obra.technique}
            dimensions={obra.dimensions}
            index={i}
          />
        </div>
      ))}
    </div>
    <div class="mt-16 text-center">
      <a
        href="/trabajo"
        class="inline-block px-8 py-3 text-xs font-bold text-white bg-ink hover:bg-accent transition-all duration-300 tracking-[0.2em] uppercase shadow-brush hover:shadow-brush-lg"
      >
        Ver todo el trabajo
      </a>
    </div>
  </section>
</BaseLayout>