---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroSection from '../components/HeroSection.astro'
import ArtCard from '../components/ArtCard.astro'
import obras from '../data/obras.json' with { type: 'json' }
---

<BaseLayout title="TEAS | Artista Contemporáneo" description="Portafolio de TEAS, artista contemporáneo especializado en retrato y expresividad gráfica.">
  <HeroSection
    image="/images/calipso.jpeg"
    alt="Calipso - obra destacada"
    title="TEAS"
  />

  <section class="max-w-6xl mx-auto px-6 py-20">
    <h2 class="font-display text-2xl font-bold tracking-widest uppercase text-ink mb-2">Obras recientes</h2>
    <p class="text-sm text-muted mb-10">Selección de retratos y estudios</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {obras.slice(0, 6).map((obra) => (
        <ArtCard
          title={obra.title}
          image={obra.image}
          alt={obra.alt}
          year={obra.year}
          technique={obra.technique}
          dimensions={obra.dimensions}
        />
      ))}
    </div>
    <div class="mt-12 text-center">
      <a
        href="/trabajo"
        class="inline-block px-8 py-3 text-sm font-bold text-white bg-ink hover:bg-accent transition-colors tracking-widest uppercase shadow-brush"
      >
        Ver todo el trabajo
      </a>
    </div>
  </section>
</BaseLayout>
