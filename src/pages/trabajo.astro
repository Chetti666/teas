---
import BaseLayout from '../layouts/BaseLayout.astro'
import ArtCard from '../components/ArtCard.astro'
import obras from '../data/obras.json' with { type: 'json' }
---

<BaseLayout title="Trabajo | TEAS" description="Galería completa de obras de TEAS.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <h1 class="font-display text-3xl font-bold tracking-widest uppercase text-ink mb-2">Trabajo</h1>
    <p class="text-sm text-muted mb-10">Galería completa de obra individual</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {obras.map((obra) => (
        <ArtCard
          title={obra.title}
          image={obra.image}
          alt={obra.alt}
          year={obra.year}
          technique={obra.technique}
          dimensions={obra.dimensions}
        />
      ))}
    </div>
  </section>
</BaseLayout>
