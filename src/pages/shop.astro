---
import BaseLayout from '../layouts/BaseLayout.astro'
import productos from '../data/productos.json' with { type: 'json' }

const productListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Ediciones limitadas TEAS",
  "description": "Prints de arte contemporáneo de TEAS, ediciones limitadas firmadas y numeradas.",
  "url": "https://teas.cl/shop",
  "numberOfItems": productos.length,
  "itemListElement": productos.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Product",
      "name": `${p.title} — Print de TEAS`,
      "image": `https://teas.cl${p.image}`,
      "description": `Print edición limitada de "${p.title}" de TEAS. ${p.technique}. ${p.dimensions}. ${p.signature}.`,
      "brand": { "@type": "Brand", "name": "TEAS" }
    }
  }))
}
---

<BaseLayout
  title="Tienda de Arte | TEAS — Cuadros, Prints y Ediciones Limitadas"
  description="Compra obras originales y ediciones limitadas de TEAS. Cuadros, prints de arte contemporáneo, giclée sobre papel de algodón. Envíos a todo Chile."
  ogType="website"
  canonical="/shop"
>
  <script type="application/ld+json" set:html={JSON.stringify(productListLd)}>
  <section class="max-w-6xl mx-auto px-6 py-24 animate-reveal">
    <div class="max-w-xl">
      <h1 class="font-display text-base font-bold tracking-[0.1em] uppercase text-ink mb-2">Shop</h1>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {productos.map((producto, i) => (
        <article
          class="bg-white transition-all duration-500 hover:-translate-y-1"
          style={`animation: reveal 0.7s ease-out ${i * 120}ms forwards; opacity: 0;`}
        >
          <div class="overflow-hidden bg-surface">
            <img
              src={producto.image}
              alt={producto.alt}
               class="w-full h-auto object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-5 space-y-0.5">
            <h3 class="font-display text-base font-semibold uppercase tracking-[0.12em] text-ink">{producto.title}</h3>
            <p class="text-[11px] text-muted/60 uppercase tracking-wider">{producto.edition}</p>
            <p class="text-xs text-muted/50">{producto.technique}</p>
            <p class="text-[11px] text-muted/40">{producto.dimensions}</p>
            <p class="text-[11px] text-muted/40">{producto.signature}</p>
            <p class="pt-3 text-[11px] text-muted/40 uppercase tracking-wider">Próximamente disponible</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>