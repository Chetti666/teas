---
import BaseLayout from '../layouts/BaseLayout.astro'
import productos from '../data/productos.json' with { type: 'json' }
---

<BaseLayout title="Shop | TEAS" description="Tienda de ediciones limitadas de TEAS.">
  <section class="max-w-6xl mx-auto px-6 py-24 animate-reveal">
    <div class="max-w-xl">
      <h1 class="font-display text-3xl font-bold tracking-[0.15em] uppercase text-ink mb-2">Shop</h1>
      <p class="text-sm text-muted/70">Ediciones limitadas y obras disponibles</p>
    </div>
    <div class="h-px w-16 bg-stone my-8" />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {productos.map((producto, i) => (
        <article
          class="bg-white border border-stone/40 transition-all duration-500 hover:-translate-y-1"
          style={`animation: reveal 0.7s ease-out ${i * 120}ms forwards; opacity: 0;`}
        >
          <div class="overflow-hidden bg-surface">
            <img
              src={producto.image}
              alt={producto.alt}
               class="w-full h-auto object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-5 space-y-2">
            <h3 class="font-display text-base font-semibold uppercase tracking-[0.12em] text-ink">{producto.title}</h3>
            <p class="text-[11px] text-muted/60 uppercase tracking-wider">{producto.edition}</p>
            <p class="text-xs text-muted/50">{producto.technique}</p>
            <p class="text-[11px] text-muted/40">{producto.dimensions}</p>
            <p class="text-[11px] text-muted/40">{producto.signature}</p>
            <div class="pt-4 flex items-center justify-between border-t border-stone/60">
              <span class="font-display text-base font-bold text-ink">
                ${producto.price.toLocaleString('es-CL')} CLP
              </span>
              <button
                class="px-4 py-2 text-[11px] font-bold text-white bg-ink hover:bg-accent transition-all duration-300 uppercase tracking-[0.12em]"
                onclick="alert('Agregado al carrito: {producto.title}')"
              >
                Agregar
              </button>
            </div>
            {producto.stock <= 5 && (
              <p class="text-[11px] text-accent font-medium tracking-wide">
                Quedan {producto.stock} unidades
              </p>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>