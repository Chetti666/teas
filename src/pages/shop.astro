---
import BaseLayout from '../layouts/BaseLayout.astro'
import productos from '../data/productos.json' with { type: 'json' }
---

<BaseLayout title="Shop | TEAS" description="Tienda de ediciones limitadas de TEAS.">
  <section class="max-w-6xl mx-auto px-6 py-20">
    <h1 class="font-display text-3xl font-bold tracking-widest uppercase text-ink mb-2">Shop</h1>
    <p class="text-sm text-muted mb-10">Ediciones limitadas y obras disponibles</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {productos.map((producto) => (
        <article class="bg-white border border-ink/10 shadow-brush">
          <div class="overflow-hidden">
            <img
              src={producto.image}
              alt={producto.alt}
              class="w-full h-auto object-cover transition-transform duration-700 hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-5 space-y-2">
            <h3 class="font-display text-lg font-bold uppercase tracking-widest text-ink">{producto.title}</h3>
            <p class="text-xs text-muted uppercase tracking-wider">{producto.edition}</p>
            <p class="text-sm text-muted">{producto.technique}</p>
            <p class="text-xs text-muted/60">{producto.dimensions}</p>
            <p class="text-xs text-muted/60">{producto.signature}</p>
            <div class="pt-3 flex items-center justify-between border-t border-stone">
              <span class="font-display text-lg font-bold text-ink">
                ${producto.price.toLocaleString('es-CL')} CLP
              </span>
              <button
                class="px-4 py-2 text-xs font-bold text-white bg-ink hover:bg-accent transition-colors uppercase tracking-wider"
                onclick="alert('Agregado al carrito: {producto.title}')"
              >
                Agregar
              </button>
            </div>
            {producto.stock <= 5 && (
              <p class="text-xs text-accent font-medium">
                Quedan {producto.stock} unidades
              </p>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
