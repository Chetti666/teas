---
import BaseLayout from '../layouts/BaseLayout.astro'
import exhibiciones from '../data/exhibiciones.json' with { type: 'json' }

const sorted = [...exhibiciones].sort((a, b) => b.year - a.year)
const years = [...new Set(sorted.map((e) => e.year))]
---

<BaseLayout
  title="Exhibiciones | TEAS — Muestras y Proyectos"
  description="Exhibiciones y proyectos curatoriales de TEAS en galerías y centros culturales de Santiago y Valparaíso. Arte contemporáneo chileno en espacios expositivos."
  ogType="article"
  canonical="/exhibiciones"
>
  <section class="max-w-4xl mx-auto px-6 py-24 animate-reveal">
    <div class="max-w-xl">
      <h1 class="font-display text-base font-bold tracking-[0.1em] uppercase text-ink mb-2">Exhibiciones</h1>
    </div>
    {years.map((year, yi) => (
      <div class="mb-16 last:mb-0" style={`animation: reveal 0.7s ease-out ${yi * 150}ms forwards; opacity: 0;`}>
        <h2 class="font-display text-lg font-bold tracking-[0.2em] text-ink mb-8 pb-3 border-b border-stone/60">
          {year}
        </h2>
        <div class="space-y-6">
          {sorted.filter((e) => e.year === year).map((expo, ei) => (
            <article class="bg-white p-6 transition-all duration-300">
              <h3 class="font-display text-base font-bold uppercase tracking-[0.12em] text-ink">{expo.title}</h3>
              <p class="text-xs font-medium text-accent mt-1.5 tracking-wide">{expo.venue}, {expo.city}</p>
              <p class="text-sm text-muted/70 mt-3 leading-relaxed">{expo.description}</p>
            </article>
          ))}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>