---
export interface Props {
  title: string
  image: string
  alt: string
  year?: number
  technique?: string
  dimensions?: string
  index?: number
}

const { title, image, alt, year, technique, dimensions, index = 0 } = Astro.props
---

<div
  class="relative bg-white transition-all duration-500 hover:-translate-y-1"
  style={`animation-delay: ${index * 120}ms`}
>
    <div class="overflow-hidden bg-surface">
    <img
      src={image}
      alt={alt}
      class="w-full h-auto object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="py-2.5 space-y-0.5">
    <h3 class="font-display text-sm font-semibold uppercase tracking-[0.12em] text-ink">{title}</h3>
    {year && <p class="text-xs font-medium text-muted">{year}</p>}
    {technique && <p class="text-xs text-muted/60 leading-relaxed">{technique}</p>}
    {dimensions && <p class="text-xs text-muted/40">{dimensions}</p>}
  </div>
</div>