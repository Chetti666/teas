---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

export interface Props {
  title?: string
  description?: string
  ogImage?: string
  ogType?: string
  canonical?: string
}

const siteUrl = 'https://teas.cl'

const {
  title = 'TEAS | Arte Contemporáneo — Pintura, Acrílico, Murales y Retratos',
  description = 'Seba TEAS, artista contemporáneo chileno. Obras en pintura acrílica, retratos expresivos, murales y graffiti. Arte contemporáneo desde Santiago, Chile.',
  ogImage = '/images/calipso.jpeg',
  ogType = 'website',
  canonical,
} = Astro.props

const currentUrl = canonical ? `${siteUrl}${canonical}` : Astro.url.href
const imageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`

const breadcrumbMap: Record<string, string> = {
  '/': 'TEAS',
  '/trabajo': 'Pinturas',
  '/exhibiciones': 'Exhibiciones',
  '/mural': 'Murales',
  '/shop': 'Store',
  '/bio': 'Bio',
  '/contacto': 'Contacto',
}

const path = canonical ?? Astro.url.pathname
const breadcrumbName = breadcrumbMap[path]
const breadcrumbLd = breadcrumbName && path !== '/' ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'TEAS', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: breadcrumbName, item: `${siteUrl}${path}` },
  ],
} : null
---


<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta name="description" content={description} />
    <meta name="keywords" content="arte contemporáneo, cuadros, pintura, acrílico, murales, graffiti, canvas, seba teas, retratos, artista chileno" />
    <meta name="author" content="Seba TEAS" />

    <link rel="canonical" href={currentUrl} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="TEAS" />
    <meta property="og:locale" content="es_CL" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />


    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Seba TEAS",
        "givenName": "Seba",
        "familyName": "TEAS",
        "url": "https://teas.cl",
        "image": "https://teas.cl/images/calipso.jpeg",
        "jobTitle": "Artista contemporáneo",
        "description": "Artista contemporáneo chileno especializado en pintura acrílica, retratos, murales y graffiti.",
        "knowsAbout": ["Arte contemporáneo", "Pintura acrílica", "Retratos", "Murales", "Graffiti"],
        "email": "Sebateas1@gmail.com",
        "sameAs": [
          "https://instagram.com/teas.1"
        ]
      }
    </script>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "TEAS",
        "url": "https://teas.cl",
        "description": "Portafolio de TEAS, artista contemporáneo chileno. Obras en pintura acrílica, retratos y murales.",
        "inLanguage": "es-CL"
      }
    </script>

    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)}></script>}
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-ink antialiased">
    <Header currentPath={Astro.url.pathname} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
