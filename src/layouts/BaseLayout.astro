---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

export interface Props {
  title?: string
  description?: string
}

const { title = 'TEAS', description = 'Artista contemporáneo' } = Astro.props
const currentPath = Astro.url.pathname
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-ink antialiased">
    <Header currentPath={currentPath} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
